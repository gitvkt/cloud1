-- Tabela USUARIO
CREATE TABLE USUARIO (
  id_usuario_pk INT NOT NULL AUTO_INCREMENT PRIMARY KEY,
  uuid_usuario CHAR(30) NOT NULL,
  apelido_usuario VARCHAR(50),
  email_usuario VARCHAR(120),
  senha_usuario_hash VARCHAR(120),
  status_usuario ENUM('Ativo','Inativo','Suspenso'),
  nivel_acesso_usuario ENUM('Admin','Gestor','Usuario'),
  celular_auth VARCHAR(18) NOT NULL,
  whatsapp_auth VARCHAR(18) NOT NULL,
  data_nascimento_usuario DATE NOT NULL,
  data_cadastro_usuario TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  data_atualizacao_usuario TIMESTAMP NULL,
  data_exclusao_usuario TIMESTAMP NULL
);

-- Tabela USUARIO_BIO
CREATE TABLE USUARIO_BIO (
  id_usuario_bio_pk INT NOT NULL AUTO_INCREMENT PRIMARY KEY,
  id_usuario_fk INT NOT NULL,
  foto_perfil_usuario VARCHAR(50),
  genero_usuario ENUM('Masculino','Feminino','Outro'),
  altura_usuario DECIMAL(6,2),
  peso_usuario DECIMAL(6,3),
  observacoes_usuario VARCHAR(150),
  data_atualizacao_bio TIMESTAMP NULL,
  FOREIGN KEY (id_usuario_fk) REFERENCES USUARIO(id_usuario_pk)
);

-- Tabela USUARIO_CONTATO
CREATE TABLE USUARIO_CONTATO (
  id_usuario_contato_pk INT NOT NULL AUTO_INCREMENT PRIMARY KEY,
  id_usuario_fk INT NOT NULL,
  tipo_contato ENUM('Residencial','Comercial','Outro'),
  cep_usuario CHAR(9),
  logradouro_usuario VARCHAR(150),
  numero_usuario VARCHAR(10),
  complemento_usuario VARCHAR(50),
  bairro_usuario VARCHAR(50),
  cidade_usuario VARCHAR(50),
  estado_usuario CHAR(2),
  telefone_fixo_usuario VARCHAR(15),
  email_secundario_usuario VARCHAR(120),
  data_cadastro_contato TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  data_atualizacao_contato TIMESTAMP NULL,
  FOREIGN KEY (id_usuario_fk) REFERENCES USUARIO(id_usuario_pk)
);

