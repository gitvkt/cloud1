-- Tabela ORGANIZACAO
CREATE TABLE ORGANIZACAO (
  id_organizacao_pk INT NOT NULL AUTO_INCREMENT PRIMARY KEY,
  uuid_organizacao CHAR(30) NOT NULL,
  cnpj_organizacao VARCHAR(20) NOT NULL,
  nome_fantasia_organizacao VARCHAR(120),
  razao_social_organizacao VARCHAR(120),
  natureza_juridica VARCHAR(50),
  porte VARCHAR(50),
  situacao_cadastral VARCHAR(50),
  data_abertura DATE,
  atividade_principal VARCHAR(120),
  atividades_secundarias VARCHAR(120),
  logradouro VARCHAR(150),
  numero VARCHAR(10),
  complemento VARCHAR(50),
  bairro VARCHAR(50),
  cidade VARCHAR(50),
  estado CHAR(2),
  cep VARCHAR(9),
  telefone VARCHAR(15),
  email VARCHAR(120),
  inscricao_estadual VARCHAR(50),
  codigo_suframa VARCHAR(50),
  status_organizacao ENUM('Ativa','Inativa','Suspensa','Bloqueada'),
  nivel_plano_organizacao ENUM('Master','Nivel1','Nivel2','Nivel3'),
  data_cadastro_organizacao TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  data_atualizacao_organizacao TIMESTAMP NULL
);

-- Tabela CLIENTE_ORGANIZACAO
CREATE TABLE CLIENTE_ORGANIZACAO (
  id_cliente_organizacao_pk INT NOT NULL AUTO_INCREMENT PRIMARY KEY,
  uuid_cliente_organizacao CHAR(30) NOT NULL,
  id_cliente_fk INT NOT NULL,
  id_organizacao_fk INT NOT NULL,
  FOREIGN KEY (id_cliente_fk) REFERENCES CLIENTE(id_cliente_pk),
  FOREIGN KEY (id_organizacao_fk) REFERENCES ORGANIZACAO(id_organizacao_pk)
);
