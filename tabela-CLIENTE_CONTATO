CREATE TABLE CLIENTE_CONTATO (
	-- Dado Identificado único da tabela. Relação (1:N)
    id_cliente_contato INT AUTO_INCREMENT PRIMARY KEY,
    id_cliente_fk INT NOT NULL,
    
    
    -- Dados de Contato
    celular VARCHAR(15) NOT NULL UNIQUE,
    whatsapp_contato VARCHAR(18) NOT NULL UNIQUE,
    telegram VARCHAR(18) NULL,
    
    -- Regra de chave estrangeira
    CONSTRAINT regra_cliente_contato -- Regra para chave estrangeira. Deve ter nome (boa prática)
    FOREIGN KEY (id_cliente_fk) -- Nome da chave estrangeira criada acima
    REFERENCES CLIENTE(id_cliente) -- Nome da tabela PAI e sua coluna, da qual, será apontada e referenciada 
    ON DELETE CASCADE  -- Comando que garante que se o cliente for deletado, o contato também seja. (evita dados órfãos.)
);
