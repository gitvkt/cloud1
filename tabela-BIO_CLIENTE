CREATE TABLE BIO_CLIENTE (
    -- Identificação da TABELA 
	id_bio_cliente INT AUTO_INCREMENT PRIMARY KEY,
    id_bio_cliente_fk INT NOT NULL UNIQUE,
    
    -- Dados que serão coletados para a BIO do cliente
    sexo ENUM("Masculino", "Feminino", "Outros") NULL,
    altura DECIMAL(3,2) NULL,
    peso DECIMAL(6,3) NULL,
    observacoes TEXT NULL,
    
    CONSTRAINT fk_id_bio_cliente -- Nome da regra da chave estrangeira
    FOREIGN KEY (id_bio_cliente_fk) -- Nome da chave estrangeira que irá refenciar
    REFERENCES CLIENTE(id_cliente) -- Nome da chave estrangeira referenciada da tabela CLIENTE na coluna PK id_cliente 
    ON DELETE CASCADE -- Regra que garante que seja deletada junto ao cadastro do CLIENTE, evitando lixo no BD
);
